# =============================================
#  SisacademiChat - Configuracion del Cliente
# =============================================

# Servicio
PORT=8090
HOST=127.0.0.1

# Seguridad
API_KEY=cambiar-esta-clave-en-produccion
RATE_LIMIT_PER_MINUTE=30

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b        # modelo base (multilingue, fuerte en espanol)

# Modelos por tarea (opcional; si no se definen, usan OLLAMA_MODEL)
OLLAMA_MODEL_FAST=qwen2.5:1.5b   # chat estudiantes (espanol)
OLLAMA_MODEL_ENGLISH=llama3.2:1b # respuestas en ingles (llama es nativo en EN)
OLLAMA_MODEL_MEDIUM=qwen2.5:1.5b # fallback cuando el retrieval es debil
OLLAMA_MODEL_SMART=qwen2.5:1.5b  # reportes profesor (subir a qwen2.5:3b si hay RAM)

# Idioma estricto: si true, todas las respuestas son en espanol (ignora deteccion EN).
# Recomendado solo si usas un modelo muy pequeno que mezcla idiomas (qwen2.5:0.5b).
STRICT_SPANISH_ONLY=false

# Ollama Performance (ajustar segun hardware)
OLLAMA_NUM_CTX=2048              # contexto LLM (tokens) — sube si tienes RAM
OLLAMA_NUM_PREDICT=300           # max tokens de salida (300 = ~220 palabras, suficiente)
OLLAMA_TEMPERATURE=0.0           # 0.0 = totalmente determinista (anti-alucinacion)
OLLAMA_KEEP_ALIVE=10m
OLLAMA_READ_TIMEOUT=120

# RAG
TOP_K=4                          # cantidad de chunks recuperados por consulta
MAX_QUERY_LENGTH=500
MIN_RELEVANCE_SCORE=0.18         # umbral por chunk para incluirlo en el contexto
MIN_TOP_SCORE_TO_ANSWER=0.28     # umbral del mejor chunk; debajo = NO_INFO sin LLM
MAX_CHUNK_LENGTH=520             # truncado de chunks largos antes de mandar al LLM
MAX_CONTEXT_CHUNKS=5             # max chunks unidos como contexto

# Filtro de fuentes ficticias — patrones del nombre de fuente separados por coma
# Ejemplo: FICTIONAL_SOURCE_PATTERNS=pepita,cuento,historia_de
FICTIONAL_SOURCE_PATTERNS=

# Cache de respuestas RAG (preguntas repetidas se responden sin tocar Ollama)
QUERY_CACHE_TTL=3600       # segundos que una respuesta permanece en cache (0 = desactivar)
QUERY_CACHE_MAX_SIZE=200   # maximo de respuestas cacheadas en memoria

# Servidor central (para sincronizar KB y logs)
SERVER_URL=http://ejemplo.com:8091
SERVER_API_KEY=clave-api-servidor
DEVICE_ID=
