# =============================================
#  SisacademiChat - Configuracion del Cliente
# =============================================

# Servicio
PORT=8090
HOST=127.0.0.1

# Seguridad
API_KEY=cambiar-esta-clave-en-produccion
RATE_LIMIT_PER_MINUTE=30

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Ollama Performance (ajustar segun hardware)
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.1
OLLAMA_KEEP_ALIVE=30m

# RAG
TOP_K=3
MAX_QUERY_LENGTH=500
MIN_RELEVANCE_SCORE=0.25
MAX_CHUNK_LENGTH=500

# Servidor central (para sincronizar KB y logs)
SERVER_URL=http://ejemplo.com:8091
SERVER_API_KEY=clave-api-servidor
DEVICE_ID=
